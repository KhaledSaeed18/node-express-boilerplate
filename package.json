{
    "name": "node-express-boilerplate",
    "version": "1.0.0",
    "license": "MIT",
    "description": "Simple and secure notes app built with Express.js, TypeScript, Prisma ORM, and PostgreSQL",
    "main": "dist/index.js",
    "engines": {
        "node": ">=22.0.0",
        "pnpm": ">=10.0.0"
    },
    "packageManager": "pnpm@10.28.0",
    "scripts": {
        "dev": "nodemon src/index.ts",
        "build": "tsc",
        "start": "node dist/index.js",
        "type-check": "tsc --noEmit",
        "format": "prettier --write \"src/**/*.ts\"",
        "format:check": "prettier --check \"src/**/*.ts\"",
        "lint": "eslint \"src/**/*.ts\" --fix",
        "lint:check": "eslint \"src/**/*.ts\"",
        "full-check": "pnpm format:check && pnpm lint:check && pnpm type-check",
        "prepare": "husky",
        "prisma:studio": "pnpm exec prisma studio",
        "prisma:generate": "pnpm exec prisma generate",
        "prisma:migrate": "pnpm exec prisma migrate dev",
        "prisma:migrate:reset": "pnpm exec prisma migrate reset --force",
        "prisma:migrate:deploy": "pnpm exec prisma migrate deploy",
        "prisma:db:pull": "pnpm exec prisma db pull",
        "prisma:db:push": "pnpm exec prisma db push",
        "prisma:db:seed": "pnpm exec prisma db seed",
        "prisma:validate": "pnpm exec prisma validate",
        "type-check:test": "tsc --project tsconfig.test.json",
        "type-check:node": "tsc --project tsconfig.node.json",
        "test": "vitest run --config vitest.unit.config.ts",
        "test:watch": "vitest --config vitest.unit.config.ts",
        "test:integration": "vitest run --config vitest.integration.config.ts",
        "test:all": "pnpm test && pnpm test:integration",
        "test:coverage": "vitest run --coverage --config vitest.unit.config.ts",
        "test:coverage:integration": "vitest run --coverage --config vitest.integration.config.ts",
        "db:test:up": "docker compose -f docker-compose.test.yml up -d",
        "db:test:down": "docker compose -f docker-compose.test.yml down -v",
        "db:test:migrate": "dotenv -e .env.test -- prisma migrate deploy"
    },
    "keywords": [
        "express",
        "typescript",
        "prisma",
        "postgresql",
        "rate-limit",
        "security",
        "validation",
        "authentication",
        "jwt",
        "bcrypt",
        "cookie-parser",
        "cors",
        "helmet",
        "notes-app"
    ],
    "dependencies": {
        "@prisma/adapter-pg": "^7.8.0",
        "@prisma/client": "^7.8.0",
        "bcryptjs": "^3.0.3",
        "cookie-parser": "^1.4.7",
        "cors": "^2.8.6",
        "csrf-csrf": "^4.0.3",
        "dotenv": "^17.4.2",
        "express": "^5.2.1",
        "express-rate-limit": "^8.4.1",
        "helmet": "^8.1.0",
        "http-errors": "^2.0.1",
        "jsonwebtoken": "^9.0.3",
        "pino": "^10.3.1",
        "pino-http": "^11.0.0",
        "prisma": "^7.8.0",
        "swagger-ui-express": "^5.0.1",
        "zod": "^4.4.3"
    },
    "devDependencies": {
        "@commitlint/cli": "^20.5.3",
        "@commitlint/config-conventional": "^20.5.3",
        "@types/bcryptjs": "^3.0.0",
        "@types/cookie-parser": "^1.4.10",
        "@types/cors": "^2.8.19",
        "@types/express": "^5.0.6",
        "@types/http-errors": "^2.0.5",
        "@types/jsonwebtoken": "^9.0.10",
        "@types/node": "^25.6.0",
        "@types/supertest": "^7.2.0",
        "@types/swagger-ui-express": "^4.1.8",
        "@vitest/coverage-v8": "^4.1.5",
        "eslint": "^10.3.0",
        "eslint-config-prettier": "^10.1.8",
        "husky": "^9.1.7",
        "lint-staged": "^16.4.0",
        "nodemon": "^3.1.14",
        "pino-pretty": "^13.1.3",
        "prettier": "^3.8.3",
        "supertest": "^7.2.2",
        "ts-node": "^10.9.2",
        "tsx": "^4.21.0",
        "typescript": "^6.0.3",
        "typescript-eslint": "^8.59.1",
        "vitest": "^4.1.5"
    },
    "lint-staged": {
        "src/**/*.ts": [
            "prettier --write",
            "eslint --fix"
        ]
    },
    "pnpm": {
        "onlyBuiltDependencies": [
            "@prisma/client",
            "@prisma/engines",
            "prisma"
        ],
        "overrides": {
            "picomatch": ">=2.3.2"
        }
    }
}
