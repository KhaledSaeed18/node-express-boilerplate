{
    "name": "node-express-boilerplate",
    "version": "1.0.0",
    "license": "MIT",
    "description": "Simple and secure notes app built with Express.js, TypeScript, Prisma ORM, and PostgreSQL",
    "main": "dist/index.js",
    "engines": {
        "node": ">=22.0.0",
        "pnpm": ">=10.0.0"
    },
    "packageManager": "pnpm@10.28.0",
    "scripts": {
        "dev": "nodemon src/index.ts",
        "build": "tsc",
        "start": "node dist/index.js",
        "type-check": "tsc --noEmit",
        "format": "prettier --write \"src/**/*.ts\"",
        "format:check": "prettier --check \"src/**/*.ts\"",
        "lint": "eslint \"{src,apps,libs,test}/**/*.ts\" --fix",
        "lint:check": "eslint \"{src,apps,libs,test}/**/*.ts\"",
        "type:check": "tsc --noEmit",
        "full-check": "pnpm format:check && pnpm lint:check && pnpm type:check",
        "prepare": "husky",
        "prisma:studio": "pnpm exec prisma studio",
        "prisma:generate": "pnpm exec prisma generate",
        "prisma:migrate": "pnpm exec prisma migrate dev --name init",
        "prisma:migrate:reset": "pnpm exec prisma migrate reset --force",
        "prisma:migrate:deploy": "pnpm exec prisma migrate deploy",
        "prisma:db:pull": "pnpm exec prisma db pull",
        "prisma:db:push": "pnpm exec prisma db push",
        "prisma:db:seed": "pnpm exec prisma db seed",
        "prisma:validate": "pnpm exec prisma validate"
    },
    "prisma": {
        "seed": "ts-node prisma/seed.ts"
    },
    "keywords": [
        "express",
        "typescript",
        "prisma",
        "postgresql",
        "rates-limit",
        "security",
        "validation",
        "authentication",
        "jwt",
        "bcrypt",
        "cookie-parser",
        "cors",
        "helmet",
        "morgan",
        "notes-app"
    ],
    "dependencies": {
        "@prisma/adapter-pg": "^7.7.0",
        "@prisma/client": "^7.7.0",
        "bcryptjs": "^3.0.3",
        "cookie-parser": "^1.4.7",
        "cors": "^2.8.6",
        "dotenv": "^17.4.2",
        "express": "^5.2.1",
        "express-rate-limit": "^8.3.2",
        "express-validator": "^7.3.2",
        "helmet": "^8.1.0",
        "jsonwebtoken": "^9.0.3",
        "morgan": "^1.10.1",
        "prisma": "^7.7.0"
    },
    "devDependencies": {
        "@commitlint/cli": "^20.5.0",
        "@commitlint/config-conventional": "^20.5.0",
        "@types/cookie-parser": "^1.4.10",
        "@types/cors": "^2.8.19",
        "@types/express": "^5.0.6",
        "@types/jsonwebtoken": "^9.0.10",
        "@types/morgan": "^1.9.10",
        "@types/node": "^25.6.0",
        "eslint": "^10.2.0",
        "eslint-config-prettier": "^10.1.8",
        "husky": "^9.1.7",
        "lint-staged": "^16.4.0",
        "nodemon": "^3.1.14",
        "prettier": "^3.8.2",
        "ts-node": "^10.9.2",
        "typescript": "^6.0.2",
        "typescript-eslint": "^8.58.1"
    },
    "lint-staged": {
        "src/**/*.ts": [
            "prettier --write",
            "eslint --fix"
        ]
    },
    "pnpm": {
        "onlyBuiltDependencies": [
            "@prisma/client",
            "@prisma/engines",
            "prisma"
        ],
        "overrides": {
            "picomatch": ">=2.3.2"
        }
    }
}
